name: Build 8Ball Pool Tweak

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: macos-latest
    steps:
      - name: Create source files
        run: |
          mkdir -p 8ball-tweak/src
          echo "" | base64 --decode > 8ball-tweak/Makefile
          echo ""  | base64 --decode > 8ball-tweak/control
          echo ""   | base64 --decode > 8ball-tweak/src/Tweak.x
          echo ""     | base64 --decode > 8ball-tweak/src/OverlayWindow.h
          echo ""     | base64 --decode > 8ball-tweak/src/OverlayWindow.m
          echo ""    | base64 --decode > 8ball-tweak/src/AimOverlayView.h
          echo ""    | base64 --decode > 8ball-tweak/src/AimOverlayView.m
          echo ""     | base64 --decode > 8ball-tweak/src/AutoShooter.h
          echo ""     | base64 --decode > 8ball-tweak/src/AutoShooter.m

      - name: Install Theos
        run: |
          bash -c "$(curl -fsSL https://raw.githubusercontent.com/theos/theos/master/bin/install-theos)"
          echo "THEOS=$HOME/theos" >> $GITHUB_ENV
          echo "$HOME/theos/bin" >> $GITHUB_PATH

      - name: Download iOS SDK
        run: |
          curl -L -o sdk.tar.xz https://github.com/theos/sdks/releases/latest/download/iPhoneOS16.5.sdk.tar.xz
          tar -xf sdk.tar.xz -C $HOME/theos/sdks/

      - name: Build
        run: |
          export THEOS=$HOME/theos
          cd 8ball-tweak
          make package FINALPACKAGE=1

      - name: Upload deb
        uses: actions/upload-artifact@v4
        with:
          name: EightBallAim-deb
          path: 8ball-tweak/packages/*.deb

      - name: Upload dylib
        uses: actions/upload-artifact@v4
        with:
          name: EightBallAim-dylib
          path: 8ball-tweak/.theos/obj/EightBallAim.dylib
